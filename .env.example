# =============================================================================
# PwnDoc-NG Environment Configuration
# Copy this file to .env and customize for your deployment
# =============================================================================

# --- Application ---
NODE_ENV=prod
APP_PORT=4242
APP_HOST=
COLLAB_WEBSOCKET_PORT=8440

# --- MongoDB ---
MONGO_HOST=mongo-pwndoc-ng
MONGO_PORT=27017
MONGO_DB_NAME=pwndoc
MONGO_USERNAME=pwndoc
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# --- JWT Secrets (REQUIRED for production — generate with: openssl rand -hex 32) ---
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- CORS ---
# Comma-separated list of allowed origins, or * for all (not recommended for production)
# Example: https://pwndoc.example.com
CORS_ORIGIN=*

# --- Body Parser Limit ---
BODY_LIMIT=20mb

# --- API Documentation ---
APIDOC=false
